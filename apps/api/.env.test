# ──────────────────────────────────────────────────────────────────
# E2E Test Environment
# ──────────────────────────────────────────────────────────────────
# These values are used by vitest.e2e.config.ts and global-setup.ts.
# They must match the postgres-test service in docker/docker-compose.yml.
#
# This file is committed to git — it contains NO secrets.
# The credentials here are for a local ephemeral test database only.
# ──────────────────────────────────────────────────────────────────

NODE_ENV=test
LOG_LEVEL=silent

# Must match docker-compose.yml postgres-test service
DATABASE_URL_TEST=postgresql://paisa_test:paisa_test@localhost:5433/paisa_test

# Required by env validation (safe test-only values)
JWT_SECRET=test-jwt-secret-that-is-at-least-32-characters-long
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
