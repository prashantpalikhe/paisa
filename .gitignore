# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
*.tsbuildinfo
.output/
.nuxt/
.turbo/

# Environment
.env
.env.local
.env.*.local

# IDE
# .vscode/ is NOT gitignored — we commit launch.json, extensions.json, and
# settings.json so all contributors get a consistent dev experience.
# Only personal workspace files (*.code-workspace) are ignored.
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Prisma
packages/db/prisma/*.db
packages/db/prisma/*.db-journal
packages/db/src/generated/

# Test
coverage/
playwright-report/
test-results/

# Logs
*.log
pino-pretty.log

# Docker volumes
docker/data/

# Uploads (local storage)
uploads/
