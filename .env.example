# ──────────────────────────────────────────────────────────────────
# Paisa Boilerplate — Environment Variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# All FEATURE_* flags default to false (disabled) when not set.
# ──────────────────────────────────────────────────────────────────

# ─── Core (NestJS) ───
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# ─── Nuxt Runtime Config Overrides ───
# Nuxt 4 requires NUXT_PUBLIC_* env vars to override runtimeConfig.public at runtime.
# These are read by both apps/web and apps/admin.
NUXT_PUBLIC_API_BASE_URL=http://localhost:3001
NUXT_PUBLIC_SENTRY_DSN=

# ─── Database ───
DATABASE_URL=postgresql://paisa:paisa@localhost:5432/paisa
DATABASE_URL_TEST=postgresql://paisa_test:paisa_test@localhost:5433/paisa_test

# ─── Auth ───
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
WEBAUTHN_RP_NAME=Paisa Dev
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── Logging ───
LOG_LEVEL=debug

# ─── Feature Flags (Infrastructure) ───
# Set to "true" to enable. When enabled, provide the required config below.
FEATURE_AUTH_GOOGLE_ENABLED=false
FEATURE_AUTH_PASSKEY_ENABLED=true
FEATURE_AUTH_2FA_ENABLED=true
FEATURE_EMAIL_ENABLED=false
FEATURE_STRIPE_ENABLED=false
FEATURE_REDIS_ENABLED=false
FEATURE_RABBITMQ_ENABLED=false
FEATURE_STORAGE_ENABLED=false
FEATURE_WEBSOCKETS_ENABLED=false
FEATURE_SENTRY_ENABLED=false

# ─── Google OAuth (when FEATURE_AUTH_GOOGLE_ENABLED=true) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─── Redis (when FEATURE_REDIS_ENABLED=true) ───
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ (when FEATURE_RABBITMQ_ENABLED=true) ───
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
RABBITMQ_MANAGEMENT_USER=guest
RABBITMQ_MANAGEMENT_PASSWORD=guest

# ─── Stripe (when FEATURE_STRIPE_ENABLED=true) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email / Resend (when FEATURE_EMAIL_ENABLED=true) ───
RESEND_API_KEY=re_...
EMAIL_FROM=dev@yourdomain.com

# ─── Cloudflare R2 (when FEATURE_STORAGE_ENABLED=true and STORAGE_PROVIDER=r2) ───
STORAGE_PROVIDER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=paisa-uploads
R2_PUBLIC_URL=

# ─── Sentry (when FEATURE_SENTRY_ENABLED=true) ───
# Used by NestJS directly; Nuxt reads NUXT_PUBLIC_SENTRY_DSN above
SENTRY_DSN=
